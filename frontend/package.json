{
  "name": "local-chess",
  "version": "0.1.0",
  "description": "A high-performance browser-based chess engine and UI built with Vite, React, and TypeScript. Features local multiplayer and Stockfish-powered AI.",
  "keywords": [
    "chess",
    "react",
    "typescript",
    "vite",
    "stockfish",
    "ai",
    "browser-game",
    "local-multiplayer"
  ],
  "author": "cburns",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "test": "vitest run",
    "lint": "oxlint",
    "format": "oxfmt",
    "prepare": "husky",
    "lint:fix": "oxlint --fix . && oxfmt"
  },
  "dependencies": {
    "@microsoft/signalr": "^10.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stockfish": "^18.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "oxlint --fix",
      "oxfmt"
    ]
  }
}
